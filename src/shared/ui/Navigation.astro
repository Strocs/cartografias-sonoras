---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Inicio', icon: 'home' },
  { href: '/proyecto', label: 'Proyecto', icon: 'document' },
  { href: '/datos', label: 'Datos', icon: 'map' },
  { href: '/equipo', label: 'Equipo', icon: 'people' }
] as const;
---

<aside class="w-62 shrink-0 p-4">
  <div
    class="border-secondary-sand/60 bg-canvas hidden h-full flex-col rounded-xl border shadow-lg md:flex"
  >
    <div class="flex flex-col gap-4 p-6 pb-4">
      <a href="/" class="flex flex-col gap-1">
        <span
          class="text-primary-brown font-serif text-lg leading-none font-black tracking-wide uppercase"
        >
          Cartografías Sensoriales
        </span>
        <span class="text-secondary-sand text-xs tracking-widest lowercase">
          Mapeo de Marcas Sonoras
        </span>
      </a>
    </div>

    <nav aria-label="Principal" class="flex-1 px-2 py-2">
      <ul class="flex flex-col gap-1">
        {
          navItems.map((item) => {
            const isActive =
              currentPath === item.href ||
              (item.href !== '/' && currentPath.startsWith(item.href));

            return (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'flex items-center gap-3 rounded-md px-3 py-2 text-sm transition-colors',
                    isActive
                      ? 'border-primary-teal bg-primary-teal/5 text-charcoal border-l-4'
                      : 'text-primary-brown hover:bg-secondary-sand/20 hover:text-charcoal'
                  ]}
                >
                  {item.icon === 'home' && (
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                      <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                  )}
                  {item.icon === 'document' && (
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                      <polyline points="14 2 14 8 20 8" />
                      <line x1="16" y1="13" x2="8" y2="13" />
                      <line x1="16" y1="17" x2="8" y2="17" />
                      <polyline points="10 9 9 9 8 9" />
                    </svg>
                  )}
                  {item.icon === 'map' && (
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="1 6 1 22 8 18 16 22 21 18 21 2 16 6 8 2 1 6" />
                      <line x1="8" y1="2" x2="8" y2="18" />
                      <line x1="16" y1="6" x2="16" y2="22" />
                    </svg>
                  )}
                  {item.icon === 'people' && (
                    <svg
                      aria-hidden="true"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                  )}
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <footer class="mt-auto p-6">
      <div class="mb-12">
        <p class="text-charcoal/50 text-sm">
          Navega por los mapas sonoros, reproduce los sonidos o la obra
          compuesta para esta área.
        </p>
      </div>
      <div class="border-secondary-sand/20 border-t">
        <div class="flex flex-col gap-3 pt-2">
          <div class="text-charcoal/70 flex items-center gap-2">
            <svg
              aria-hidden="true"
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 3L2 9l10 6 10-6-10-6z"></path>
              <path d="M2 15l10 6 10-6"></path>
              <path d="M2 9v6"></path>
              <path d="M22 9v6"></path>
              <path d="M12 15v6"></path>
            </svg>
            <span class="text-[11px] leading-tight font-semibold uppercase"
              >ULS</span
            >
          </div>
          <div class="text-charcoal/70 flex items-center gap-2">
            <svg
              aria-hidden="true"
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              ></path>
              <path d="M2 12h20"></path>
            </svg>
            <span class="text-[11px] leading-tight font-semibold uppercase"
              >Innova Creativa</span
            >
          </div>
          <div class="text-charcoal/70 flex items-center gap-2">
            <svg
              aria-hidden="true"
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M2 12h20"></path>
              <path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              ></path>
              <path d="M12 2v20"></path>
            </svg>
            <span class="text-[11px] leading-tight font-semibold uppercase"
              >Escuela de Arquitectura</span
            >
          </div>
        </div>
      </div>
    </footer>
  </div>
</aside>
