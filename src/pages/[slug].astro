---
import Layout from '../layouts/Layout.astro';
import Navigation from '../shared/ui/Navigation.astro';
import ActiveMapLayout from '../features/maps/ui/ActiveMapLayout.astro';
import { mockMaps } from '../features/maps/data/mock-maps';
import { mockSounds } from '../features/sounds/data/mock-sounds';
import { mockPaths } from '../features/paths/data/mock-paths';
import { mockSoundPieces } from '../features/sound-pieces/data/mock-sound-pieces';

export function getStaticPaths() {
  return mockMaps.map((map) => ({ params: { slug: map.slug } }));
}

const { slug } = Astro.params;
const map = mockMaps.find((m) => m.slug === slug);

if (!map) {
  return new Response('Not found', { status: 404 });
}

const sounds = mockSounds.filter((sound) => sound.mapId === map.id);
const paths = mockPaths.filter((path) => path.mapId === map.id);
const inactiveMaps = mockMaps.filter((m) => m.slug !== slug);
const soundPiece = mockSoundPieces.find((piece) => piece.mapId === map.id) ?? null;
const title = map.title;
---

<Layout title={title}>
  <div class="flex h-screen">
    <Navigation backHref="/" />
    <main class="relative flex-1 overflow-hidden">
      <ActiveMapLayout
        slug={map.slug}
        mapImage={map.image}
        sounds={sounds}
        paths={paths}
        inactiveMaps={inactiveMaps}
        soundPiece={soundPiece}
      />
    </main>
  </div>
</Layout>
