---
import Layout from '../layouts/Layout.astro';
import Navigation from '../shared/ui/Navigation.astro';
import MapCard from '../features/maps/ui/MapCard.astro';
import { mockMaps } from '../features/maps/data/mock-maps';

const title = 'Cartografías Sensoriales';
---

<Layout title={title}>
  <div class="flex min-h-screen">
    <Navigation />
    <main class="flex-1 p-6 md:p-8">
      <h1 class="text-3xl font-bold text-primary-navy">{title}</h1>
      <p class="mt-2 max-w-2xl text-primary-brown">
        Plataforma de mapeo de marcas sonoras.
      </p>

      <section aria-label="Cartografías" class="mt-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {mockMaps.map((map) => <MapCard map={map} />)}
        </div>
      </section>
    </main>
  </div>
</Layout>
